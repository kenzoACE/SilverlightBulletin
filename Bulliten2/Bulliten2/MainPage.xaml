<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" xmlns:vsm="clr-namespace:System.Windows;assembly=System.Windows" xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls" x:Class="Bulliten2.Page" 
    Width="508" Height="396">
    <Grid x:Name="LayoutRoot" Background="White" Width="507">
        <Grid x:Name="mainBoard" Visibility="Visible" MouseWheel="mainBoard_MouseWheel">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
                <RowDefinition Height="0.065*"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="8,0,22,0" x:Name="text2" FontSize="14.667" Grid.Row="1" Text="{Binding Heading1, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text2_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text2_MouseEnter" MouseLeave="text2_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text3" FontSize="14.667" Grid.Row="2" Text="{Binding Heading2, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text3_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text3_MouseEnter" MouseLeave="text3_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text4" FontSize="14.667" Grid.Row="3" Text="{Binding Heading3, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text4_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text4_MouseEnter" MouseLeave="text4_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text5" FontSize="14.667" Grid.Row="4" Text="{Binding Heading4, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text5_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text5_MouseEnter" MouseLeave="text5_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text6" FontSize="14.667" Grid.Row="5" Text="{Binding Heading5, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text6_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text6_MouseEnter" MouseLeave="text6_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text7" FontSize="14.667" Grid.Row="6" Text="{Binding Heading6, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text7_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text7_MouseEnter" MouseLeave="text7_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text8" FontSize="14.667" Grid.Row="7" Text="{Binding Heading7, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text8_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text8_MouseEnter" MouseLeave="text8_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text9" FontSize="14.667" Grid.Row="8" Text="{Binding Heading8, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text9_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text9_MouseEnter" MouseLeave="text9_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text10" FontSize="14.667" Grid.Row="9" Text="{Binding Heading9, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text10_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text10_MouseEnter" MouseLeave="text10_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text11" FontSize="14.667" Grid.Row="10" Text="{Binding Heading10, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text11_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text11_MouseEnter" MouseLeave="text11_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text12" FontSize="14.667" Grid.Row="11" Text="{Binding Heading11, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text12_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text12_MouseEnter" MouseLeave="text12_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text13" FontSize="14.667" Grid.Row="12" Text="{Binding Heading12, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text13_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text13_MouseEnter" MouseLeave="text13_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text14" FontSize="14.667" Grid.Row="13" Text="{Binding Heading13, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text14_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text14_MouseEnter" MouseLeave="text14_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text15" FontSize="14.667" Grid.Row="14" Text="{Binding Heading14, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text15_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text15_MouseEnter" MouseLeave="text15_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text16" FontSize="14.667" Grid.Row="15" Text="{Binding Heading15, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text16_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text16_MouseEnter" MouseLeave="text16_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text17" FontSize="14.667" Grid.Row="16" Text="{Binding Heading16, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text17_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text17_MouseEnter" MouseLeave="text17_MouseLeave"/>
            <TextBlock Margin="8,0,22,0" x:Name="text18" FontSize="14.667" Grid.Row="17" Text="{Binding Heading17, Mode=OneWay}" TextWrapping="NoWrap" MouseLeftButtonDown="text18_MouseLeftButtonDown" Visibility="Visible" MouseEnter="text18_MouseEnter" MouseLeave="text18_MouseLeave"/>
            <ScrollBar HorizontalAlignment="Right" Width="18" Grid.RowSpan="17" x:Name="mainScrollBar" Scroll="mainScrollBar_Scroll" Grid.Row="1" Margin="0,-4,0,0" Background="#FF0034FF"/>
            <Button x:Name="newPostButton" Content="新規作成、投稿" Click="Button_Click" Width="250" HorizontalAlignment="Left" Height="20" Margin="0,-2,0,4" d:LayoutOverrides="HorizontalAlignment" FontSize="12" Background="#FF0029FF"/>
            <Button Margin="0,-2,0,4" Content="最新の情報に更新する" Click="Button_Click_1" Height="20" Width="257" HorizontalAlignment="Right" d:LayoutOverrides="HorizontalAlignment" FontSize="12" Background="#FF0028FF"/>
            <Canvas Margin="152,1,162,9" Grid.Row="6" Grid.RowSpan="2" x:Name="loadingCanvas" RenderTransformOrigin="0,0" Visibility="Collapsed">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="6" AngleY="-1"/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Canvas.RenderTransform>
                <Canvas.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF000000"/>
                        <GradientStop Color="#FFB3CCF4" Offset="0.317"/>
                    </LinearGradientBrush>
                </Canvas.Background>
                <TextBlock x:Name="loadingText" Height="18" Width="122" Canvas.Left="35" Canvas.Top="10" Text="ダウンロードしています" TextWrapping="Wrap"/>
            </Canvas>
        </Grid>
        <Canvas x:Name="newCanvasLayer" Visibility="Collapsed" Opacity="0.395">
            <Canvas.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF000000"/>
                    <GradientStop Color="#FF008FFF" Offset="1"/>
                </LinearGradientBrush>
            </Canvas.Background>
        </Canvas>
        <Canvas Margin="72,44,73,38" x:Name="newCanvas" Visibility="Collapsed">
            <Canvas.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#FF000000"/>
                    <GradientStop Color="#FFE1E6EE" Offset="1"/>
                </RadialGradientBrush>
            </Canvas.Background>
            <TextBlock Height="24" Width="67" FontSize="13.333" Text="タイトル：" TextWrapping="Wrap" Canvas.Left="4"/>
            <TextBlock Height="24" Width="40" FontSize="13.333" TextWrapping="Wrap" Canvas.Top="28" Canvas.Left="31"><Run Text="名前"/><Run Text="："/></TextBlock>
            <TextBlock Height="26" Width="40" FontSize="13.333" TextWrapping="Wrap" Canvas.Top="56" Canvas.Left="31"><Run Text="内容"/><Run Text="："/></TextBlock>
            <TextBox Height="28" x:Name="newTitleTextBox" FontSize="14.667" Width="289" Canvas.Left="71" Text="" TextWrapping="Wrap" MaxLength="30"/>
            <TextBox Height="26" Width="289" Text="" FontSize="14.667" TextWrapping="Wrap" x:Name="newNameTextBox" Canvas.Left="71" Canvas.Top="28" MouseEnter="newNameTextBox_MouseEnter" MaxLength="20" GotFocus="newNameTextBox_GotFocus"/>
            <TextBox Height="228" x:Name="newPostTextBox" FontSize="16" Width="352" Canvas.Left="8" Canvas.Top="78" Text="" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Cursor="Arrow"/>
            <Button Height="22" x:Name="newSendButton" Width="74" Canvas.Left="81" Canvas.Top="56" Content="送信" Click="newSendButton_Click" FontSize="12" Background="#FF004CFF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF004CFF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <Button Height="22" x:Name="newEraceButton" Width="74" Canvas.Left="286" Canvas.Top="56" Content="全消去" Click="newEraceButton_Click" FontSize="12" Background="#FF0058FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0058FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <Button Height="22" x:Name="newCancelButton" Width="74" Canvas.Left="208" Canvas.Top="56" Content="キャンセル" Click="newCancelButton_Click" FontSize="12" Background="#FF0040FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0040FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <TextBlock Height="46.545" FontSize="16" Text="エラーが発生しました。再送信してください。" TextWrapping="Wrap" x:Name="newErrorTextBlock" Width="208" Canvas.Top="149" Canvas.Left="81" Visibility="Collapsed">
            	<TextBlock.Foreground>
            		<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            			<GradientStop Color="#FF000000"/>
            			<GradientStop Color="#FFFF0000" Offset="1"/>
            		</LinearGradientBrush>
            	</TextBlock.Foreground>
            </TextBlock>
        </Canvas>
        <Canvas x:Name="displayCanvas" Visibility="Collapsed">
            <Canvas Height="396" Width="507" Background="#FFFF88FE" x:Name="cloneCanvas" Opacity="0.3" Visibility="Collapsed">
                <TextBlock Height="25" Width="321" Canvas.Left="98" Canvas.Top="143" Text="コメント数が多いためクローンされました。 " TextWrapping="Wrap" FontSize="16"/>
            </Canvas>
            <controls:TreeView x:Name="displayTreeView" FontSize="14" MaxWidth="500" Canvas.Top="24" Height="262" Width="506"/>
            <TextBox FontSize="16" Height="77" x:Name="inputTextBox" Width="290" Canvas.Left="209" Canvas.Top="311" Text="" TextWrapping="Wrap" Cursor="Arrow" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
            <Button FontSize="12" Height="25" x:Name="resetButton" Width="40" Canvas.Left="5" Canvas.Top="363" Content="消去" Click="resetButton_Click" Background="#FF0040FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0034FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <Button FontSize="12" Height="25" x:Name="sendButton" Width="76" Canvas.Left="49" Canvas.Top="364" Content="送信" Click="sendButton_Click" Background="#FF0034FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF004CFF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <TextBlock FontSize="14.667" Height="24" x:Name="titleTextBlock" Width="501" Canvas.Left="5" ToolTipService.ToolTip="{Binding ViewToolTip, Mode=OneWay}" TextWrapping="NoWrap"/>
            <TextBox Height="26" Width="134" FontSize="14.667" Text="" TextWrapping="Wrap" Canvas.Left="60" Canvas.Top="294" x:Name="replyNameTextBox" MouseEnter="replyNameTextBox_MouseEnter" GotFocus="replyNameTextBox_GotFocus" MaxLength="20"/>
            <TextBlock Height="26" FontSize="13.333" x:Name="displayNameTextBlock" Width="47" Canvas.Left="9" Canvas.Top="294" Text="名前：" TextWrapping="Wrap"/>
            <Button Height="25" FontSize="12" Width="76" Canvas.Left="128" Canvas.Top="364" Content="戻る" x:Name="closeButton" Click="closeButton_Click" Background="#FF0058FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0058FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <TextBlock Height="22" Width="116" Canvas.Left="93" Canvas.Top="330" TextWrapping="Wrap" FontSize="13.333" x:Name="displayCommentTextBlock"><Run Text="コメント"/><Run Text="を書く"/><Run Text="："/></TextBlock>
            <Button Height="25" FontSize="12" Width="40" Canvas.Left="5" Canvas.Top="327" ToolTipService.ToolTip="投稿内容を削除します。" Content="管理" x:Name="adminButton" Click="adminButton_Click" Background="#FF0058FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0058FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <TextBlock Height="47" Width="213" Canvas.Left="137" Canvas.Top="106" FontSize="16" Text="エラーが発生しました。再送信してください。" TextWrapping="Wrap" x:Name="errorTextBlock" Visibility="Collapsed">
            	<TextBlock.Foreground>
            		<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            			<GradientStop Color="#FF000000"/>
            			<GradientStop Color="#FFFF0000" Offset="1"/>
            		</LinearGradientBrush>
            	</TextBlock.Foreground>
            </TextBlock>
            <TextBlock x:Name="settingTextBlock" Height="21" Width="65" Canvas.Left="312" Canvas.Top="290" TextWrapping="Wrap" Foreground="Red" Text="新規" FontSize="14"/>
            <TextBlock Height="21" Width="100" Canvas.Left="209" Canvas.Top="290" Text="コメント位置：" TextWrapping="Wrap" FontSize="14"/>
            <Button x:Name="readButton" Height="25" Width="128" Content="コメントを読む" Canvas.Left="371" Canvas.Top="286" Background="#FF00FFC1" FontSize="12" Click="readButton_Click">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9" Offset="0"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF06FF0B" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
        </Canvas>
        <Canvas Margin="70,55,75,141" x:Name="adminCanvas" Visibility="Collapsed">
            <Canvas.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#FF000000" Offset="0"/>
                    <GradientStop Color="#FFD3FFEA" Offset="1"/>
                </RadialGradientBrush>
            </Canvas.Background>
            <Button FontSize="12" Height="23" Width="80" Canvas.Left="276" Canvas.Top="169" Content="削除" x:Name="deleteButton" Click="deleteButton_Click" Background="#FF0058FF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0058FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <Button Height="23" x:Name="adminCancelButton" Width="80" Canvas.Left="190" Canvas.Top="169" Content="キャンセル" Click="adminCancelButton_Click" Background="#FF004CFF">
                <Button.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF0058FF" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>
            <ComboBox FontSize="12" Height="24" x:Name="adminComboBox" Width="131" Canvas.Left="115" Canvas.Top="87" DropDownOpened="adminComboBox_DropDownOpened" Background="#FF0040FF">
                <ComboBox.BorderBrush>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFA3AEB9"/>
                        <GradientStop Color="#FF8399A9" Offset="0.375"/>
                        <GradientStop Color="#FF718597" Offset="0.375"/>
                        <GradientStop Color="#FF004CFF" Offset="1"/>
                    </LinearGradientBrush>
                </ComboBox.BorderBrush>
            </ComboBox>
            <TextBlock Height="22" Width="244" Canvas.Left="61" Canvas.Top="8" Text="投稿したブラウザからでのみ削除が可能です" TextWrapping="Wrap" FontSize="12"/>
            <TextBlock FontSize="12" Height="24" Width="294" Canvas.Left="61" Canvas.Top="29.455" Text="コメント番号、または掲示内容を選択してください。" TextWrapping="Wrap"/>
            <TextBlock FontSize="12" Height="18" Width="174" Canvas.Top="176" Text="削除に失敗しました。" TextWrapping="Wrap" Canvas.Left="8" x:Name="noDeleteTextBlock" Visibility="Collapsed"/>
        </Canvas>
        <ComboBox x:Name="settingComboBox" Height="27" HorizontalAlignment="Left" Margin="79,0,0,154" VerticalAlignment="Bottom" Width="119" Visibility="Collapsed"/>


    </Grid>
</UserControl>
